# Database Configuration
# Option 1: PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/litera_club

# Option 2: SQLite (Easier - No PostgreSQL needed)
# DATABASE_URL=sqlite:./litera_club.db

# Session Secret (use a strong random string in production)
SESSION_SECRET=your-secret-key-here-change-in-production

# Admin Code (for creating admin users)
ADMIN_CODE=your-admin-code-here

# Node Environment
NODE_ENV=development
